{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://2agathon.github.io/codex-control-runtime/schemas/runtime-guard-report.schema.json",
  "title": "Codex Runtime Guard diagnostic report",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "context",
    "overall",
    "acceptanceRequired",
    "checks",
    "state"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "overall": {
      "enum": ["PASS", "ATTENTION", "FAIL"]
    },
    "acceptanceRequired": {
      "const": true
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/check"
      }
    },
    "state": {
      "type": ["object", "null"]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "check": {
      "type": "object",
      "required": ["id", "layer", "status", "message", "repairable"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["PASS", "WARN", "FAIL", "UNKNOWN"]
        },
        "message": {
          "type": "string"
        },
        "repairable": {
          "type": "boolean"
        },
        "details": {}
      },
      "additionalProperties": false
    }
  }
}
